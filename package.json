{
  "name": "flare",
  "version": "1.0.0",
  "description": "Context-aware alert board for Robinhood crypto price breaks, liquidation risk, and fast market moves.",
  "license": "MIT",
  "packageManager": "bun@1.2.15",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.2.0"
  },
  "keywords": [
    "robinhood",
    "alerts",
    "coingecko",
    "trading",
    "monitoring"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FlarePriceAlert/Flare.git"
  },
  "bugs": {
    "url": "https://github.com/FlarePriceAlert/Flare/issues"
  },
  "homepage": "https://flare-launch.vercel.app/",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "tsup",
    "start": "bun run dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.3.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
